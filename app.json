{
  "expo": {
    "name": "Fmusic",
    "slug": "Fmusic",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "fmusic",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "assetBundlePatterns": ["assets/fonts/*", "assets/images/*"],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.nguyennhuhien2381997.Fmusic"
    },
    "android": {
      "edgeToEdgeEnabled": true,
      "package": "com.nguyennhuhien2381997.Fmusic"
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-localization",
      [
        "expo-video",
        {
          "supportsBackgroundPlayback": true,
          "supportsPictureInPicture": true
        }
      ],
      "expo-font"
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
